##############################################################################
## Oracle DBCA 19c – Seed Database Response File ({{ oracle_seed_sid }})
## Purpose: Software validation only – this DB will be shut down after creation
## Generated by Ansible – do not edit manually
##############################################################################

responseFileVersion=19

gdbName={{ oracle_seed_sid }}.{{ oracle_domain }}
sid={{ oracle_seed_sid }}

sysPassword={{ oracle_seed_sys_password }}
systemPassword={{ oracle_seed_system_password }}

characterSet=AL32UTF8
nationalCharacterSet=AL16UTF16

# Blank – DBCA will use $OH default location
datafileDestination=

createAsContainerDatabase=false
sampleSchema=false

memoryPercentage={{ oracle_default_memory_pct }}
automaticMemoryManagement=false

#listeners=LMT
