##############################################################################
## Oracle DBCA 19c – Customer Database Response File
## SID: {{ db.sid }}
## gdbName: {{ db.sid }}.{{ oracle_domain }}
## Generated by Ansible – do not edit manually
## Template: customer_db.rsp.j2
##
## NOTE: datafileDestination is intentionally blank.
##       All file paths are driven by the site .dbt template
##       and -honorControlFileInitParam on the DBCA command line.
##############################################################################

responseFileVersion=19

#-------------------------------------------------------------------------------
# Database identity
#-------------------------------------------------------------------------------
gdbName={{ db.sid }}.{{ oracle_domain }}
sid={{ db.sid }}

#-------------------------------------------------------------------------------
# Credentials
#-------------------------------------------------------------------------------
sysPassword={{ db.sys_password }}
systemPassword={{ db.system_password }}

#-------------------------------------------------------------------------------
# Character sets
#-------------------------------------------------------------------------------
characterSet={{ db_characterset }}
nationalCharacterSet={{ db_national_characterset }}

#-------------------------------------------------------------------------------
# Storage – blank so DBCA honours the .dbt template paths
#-------------------------------------------------------------------------------
datafileDestination=

#-------------------------------------------------------------------------------
# Non-CDB (traditional database)
#-------------------------------------------------------------------------------
createAsContainerDatabase=false

#-------------------------------------------------------------------------------
# Sample schemas – never
#-------------------------------------------------------------------------------
sampleSchema=false

#-------------------------------------------------------------------------------
# Memory
#-------------------------------------------------------------------------------
memoryPercentage={{ db_memory_pct }}
automaticMemoryManagement=false

#-------------------------------------------------------------------------------
# Listener registration
#-------------------------------------------------------------------------------
listeners=LMT
