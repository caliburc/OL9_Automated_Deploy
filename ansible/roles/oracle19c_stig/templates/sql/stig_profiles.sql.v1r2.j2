-- =============================================================================
-- STIG Profile and Password Policy Controls
-- Database : {{ stig_db.sid }}
-- STIG Ref : DISA Oracle 19c STIG V1R2
-- Generated: Ansible - do not edit manually
-- =============================================================================

SET SERVEROUTPUT ON SIZE UNLIMITED
SET FEEDBACK OFF
SET HEADING OFF

-- ── O19C-00-002800 - Create/update STIG-compliant password profile ───────────
{% if stig_O19C_002800_enabled %}
DECLARE
  v_exists NUMBER;
BEGIN
  SELECT COUNT(*) INTO v_exists
  FROM dba_profiles
  WHERE profile = '{{ stig_profile_name }}'
    AND ROWNUM = 1;

  IF v_exists = 0 THEN
    EXECUTE IMMEDIATE
      'CREATE PROFILE {{ stig_profile_name }} LIMIT
         FAILED_LOGIN_ATTEMPTS     {{ stig_failed_login_attempts }}
         PASSWORD_LIFE_TIME        {{ stig_password_life_time }}
         PASSWORD_REUSE_TIME       {{ stig_password_reuse_time }}
         PASSWORD_REUSE_MAX        {{ stig_password_reuse_max }}
         PASSWORD_LOCK_TIME        {{ stig_password_lock_time }}
         PASSWORD_GRACE_TIME       {{ stig_password_grace_time }}
         PASSWORD_VERIFY_FUNCTION  {{ stig_password_verify_function }}
         IDLE_TIME                 {{ stig_idle_time }}
         SESSIONS_PER_USER         UNLIMITED
         CPU_PER_SESSION           UNLIMITED
         CPU_PER_CALL              UNLIMITED
         LOGICAL_READS_PER_SESSION UNLIMITED
         CONNECT_TIME              UNLIMITED';
    DBMS_OUTPUT.PUT_LINE('STIG O19C-002800: Profile {{ stig_profile_name }} CREATED');
  ELSE
    EXECUTE IMMEDIATE
      'ALTER PROFILE {{ stig_profile_name }} LIMIT
         FAILED_LOGIN_ATTEMPTS     {{ stig_failed_login_attempts }}
         PASSWORD_LIFE_TIME        {{ stig_password_life_time }}
         PASSWORD_REUSE_TIME       {{ stig_password_reuse_time }}
         PASSWORD_REUSE_MAX        {{ stig_password_reuse_max }}
         PASSWORD_LOCK_TIME        {{ stig_password_lock_time }}
         PASSWORD_GRACE_TIME       {{ stig_password_grace_time }}
         PASSWORD_VERIFY_FUNCTION  {{ stig_password_verify_function }}
         IDLE_TIME                 {{ stig_idle_time }}';
    DBMS_OUTPUT.PUT_LINE('STIG O19C-002800: Profile {{ stig_profile_name }} UPDATED');
  END IF;
END;
/
{% endif %}

