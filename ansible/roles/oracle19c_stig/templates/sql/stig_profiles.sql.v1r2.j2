-- ── O19C-00-001800 - Assign STIG profile to non-privileged accounts ──────────
{% if stig_O19C_001800_enabled %}
DECLARE
  v_count NUMBER := 0;
BEGIN
  FOR u IN (
    SELECT username FROM dba_users
    WHERE username NOT IN (
      'SYS','SYSTEM','DBSNMP','SYSMAN','OUTLN','MDSYS','ORDSYS',
      'EXFSYS','DMSYS','WMSYS','CTXSYS','ANONYMOUS','XDB','ORDPLUGINS',
      'SI_INFORMTN_SCHEMA','TSMSYS','DIP','LBACSYS','SYSKM','SYSDG',
      'SYSBACKUP','AUDSYS','GGSYS','OJVMSYS','OLAPSYS','ORDDATA',
      'GSMADMIN_INTERNAL','GSMCATUSER','GSMUSER','REMOTE_SCHEDULER_AGENT',
      'DBSFWUSER','APPQOSSYS','SYS$UMF','SYSRAC','{{ oracle_stig_audit_user }}'
    )
    AND account_status NOT LIKE '%EXPIRED%'
    AND account_status NOT LIKE '%LOCKED%'
    AND profile != '{{ stig_profile_name }}'
  ) LOOP
    EXECUTE IMMEDIATE 'ALTER USER "' || u.username || '" PROFILE {{ stig_profile_name }}';
    DBMS_OUTPUT.PUT_LINE('STIG O19C-001800: Assigned {{ stig_profile_name }} to ' || u.username);
    v_count := v_count + 1;
  END LOOP;
  IF v_count = 0 THEN
    DBMS_OUTPUT.PUT_LINE('STIG O19C-001800: All eligible accounts already on {{ stig_profile_name }}');
  ELSE
    DBMS_OUTPUT.PUT_LINE('STIG O19C-001800: Profile assigned to ' || v_count || ' account(s)');
  END IF;
END;
/
{% endif %}

-- ── O19C-00-003000 - Check for default passwords ─────────────────────────────
{% if stig_O19C_003000_enabled %}
DECLARE
  v_count NUMBER;
BEGIN
  SELECT COUNT(*) INTO v_count
  FROM dba_users_with_defpwd
  WHERE username NOT IN ('XS$NULL');
  IF v_count > 0 THEN
    DBMS_OUTPUT.PUT_LINE('STIG O19C-003000: WARNING - ' || v_count || ' account(s) with default passwords found. Change or lock immediately.');
    FOR r IN (SELECT username FROM dba_users_with_defpwd WHERE username NOT IN ('XS$NULL') ORDER BY username) LOOP
      DBMS_OUTPUT.PUT_LINE('  -> ' || r.username);
    END LOOP;
  ELSE
    DBMS_OUTPUT.PUT_LINE('STIG O19C-003000: No default passwords found - COMPLIANT');
  END IF;
END;
/
{% endif %}

COMMIT;
EXIT 0;