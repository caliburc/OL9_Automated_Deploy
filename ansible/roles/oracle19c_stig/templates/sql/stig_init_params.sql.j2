-- ── O19C-00-009400 (V1R5 NEW) -- REMOTE_LOGIN_PASSWORDFILE (CAT II) ──────────
-- V1R5 V-270526: Must be EXCLUSIVE or NONE. SHARED is a finding.
-- EXCLUSIVE is required for auditing individual SYSDBA logons.
{% if stig_O19C_009400_enabled %}
DECLARE
  v_current VARCHAR2(20);
BEGIN
  SELECT value INTO v_current
  FROM   v$parameter
  WHERE  name = 'remote_login_passwordfile';
  IF UPPER(v_current) IN ('EXCLUSIVE','NONE') THEN
    DBMS_OUTPUT.PUT_LINE('STIG O19C-009400: REMOTE_LOGIN_PASSWORDFILE=' || v_current || ' -- COMPLIANT');
  ELSE
    EXECUTE IMMEDIATE 'ALTER SYSTEM SET REMOTE_LOGIN_PASSWORDFILE=''{{ stig_remote_login_passwordfile }}'' SCOPE=SPFILE';
    DBMS_OUTPUT.PUT_LINE('STIG O19C-009400: REMOTE_LOGIN_PASSWORDFILE set to {{ stig_remote_login_passwordfile }} (SPFILE -- restart required)');
  END IF;
END;
/
{% endif %}

-- ── O19C-00-012400 (V1R5 NEW) -- max_idle_time ≤ 15 minutes (CAT II) ─────────
-- V1R5 V-270550 adds an explicit check on the max_idle_time init parameter
-- in addition to the existing SQLNET.EXPIRE_TIME / PROFILE IDLE_TIME controls.
-- Query: SELECT gp.inst_id, gp.con_id, gp.value FROM sys.gv_$parameter gp
--        WHERE gp.name = 'max_idle_time';
-- If value=0 or >15, this is a finding.
{% if stig_O19C_012400_enabled %}
ALTER SYSTEM SET max_idle_time = {{ stig_max_idle_time }}
  COMMENT = 'STIG V1R5 O19C-012400 - set {{ ansible_date_time.date }}'
  SID = '*'
  SCOPE = BOTH;
BEGIN
  DBMS_OUTPUT.PUT_LINE('STIG O19C-012400 (V1R5): max_idle_time={{ stig_max_idle_time }} minutes -- APPLIED');
END;
/
{% endif %}

