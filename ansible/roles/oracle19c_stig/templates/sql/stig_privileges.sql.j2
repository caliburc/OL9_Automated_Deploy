-- ── O19C-00-011000 - ALTER SESSION - report non-admin holders ────────────────
{% if stig_O19C_011000_enabled %}
DECLARE
  v_count NUMBER := 0;
BEGIN
  FOR r IN (
    SELECT grantee FROM dba_sys_privs
    WHERE privilege = 'ALTER SESSION'
      AND grantee NOT IN (
        'SYS','SYSTEM','DBA','IMP_FULL_DATABASE','EXP_FULL_DATABASE',
        'DBSNMP','SYSMAN','WMSYS','MDSYS','LBACSYS','OLAPSYS',
        'PUBLIC','{{ oracle_stig_audit_user }}'
      )
      AND grantee NOT IN (SELECT role FROM dba_roles)
    ORDER BY grantee
  ) LOOP
    DBMS_OUTPUT.PUT_LINE('STIG O19C-011000: WARNING - ALTER SESSION granted to: ' || r.grantee || ' - review manually');
    v_count := v_count + 1;
  END LOOP;
  IF v_count = 0 THEN
    DBMS_OUTPUT.PUT_LINE('STIG O19C-011000: No unexpected ALTER SESSION grants found - COMPLIANT');
  END IF;
END;
/
{% endif %}

