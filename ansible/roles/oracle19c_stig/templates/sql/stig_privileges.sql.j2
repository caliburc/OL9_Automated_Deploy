-- ── O19C-00-002000 - Revoke sensitive packages from PUBLIC ───────────────────
{% if stig_O19C_002000_enabled %}
DECLARE
  v_count NUMBER := 0;
  v_exists NUMBER;
BEGIN
{% for pkg in stig_revoke_public_packages %}
  BEGIN
    SELECT COUNT(*) INTO v_exists FROM dba_tab_privs
    WHERE table_name = '{{ pkg }}' AND grantee = 'PUBLIC';
    IF v_exists > 0 THEN
      EXECUTE IMMEDIATE 'REVOKE EXECUTE ON {{ pkg }} FROM PUBLIC';
      DBMS_OUTPUT.PUT_LINE('STIG O19C-002000: Revoked {{ pkg }} from PUBLIC');
      v_count := v_count + 1;
    END IF;
  EXCEPTION
    WHEN OTHERS THEN
      IF SQLCODE NOT IN (-1927, -4042) THEN
        DBMS_OUTPUT.PUT_LINE('STIG O19C-002000: Note {{ pkg }}: ' || SQLERRM);
      END IF;
  END;
{% endfor %}
  IF v_count = 0 THEN
    DBMS_OUTPUT.PUT_LINE('STIG O19C-002000: No sensitive PUBLIC grants found - COMPLIANT');
  ELSE
    DBMS_OUTPUT.PUT_LINE('STIG O19C-002000: ' || v_count || ' PUBLIC grant(s) revoked');
  END IF;
END;
/
{% endif %}

