-- =============================================================================
-- POLICY 5 of 5: {{ stig_unified_audit_policy_name }}_AUD
-- Object-level DML audit on SYS.AUD$ (audit trail integrity)
-- VUL: O19C-00-002400
--
-- Also handles O19C-010100: revoke DELETE on AUD$ from non-privileged accounts.
-- =============================================================================

-- O19C-010100: Revoke DELETE on AUD$ from non-privileged accounts first
DECLARE
  v_count NUMBER := 0;
BEGIN
  FOR r IN (
    SELECT grantee
    FROM   dba_tab_privs
    WHERE  table_name = 'AUD$'
      AND  privilege  = 'DELETE'
      AND  grantee   NOT IN ('SYS','SYSTEM','AUDSYS','DBA')
    ORDER BY grantee
  ) LOOP
    EXECUTE IMMEDIATE 'REVOKE DELETE ON SYS.AUD$ FROM ' || r.grantee;
    DBMS_OUTPUT.PUT_LINE('STIG O19C-010100: DELETE on AUD$ revoked from ' || r.grantee);
    v_count := v_count + 1;
  END LOOP;
  IF v_count = 0 THEN
    DBMS_OUTPUT.PUT_LINE('STIG O19C-010100: No excess DELETE grants on AUD$ -- COMPLIANT');
  END IF;
END;
/

