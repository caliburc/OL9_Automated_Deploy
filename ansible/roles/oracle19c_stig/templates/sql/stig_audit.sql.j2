-- =============================================================================
-- POLICY 1 of 5: {{ stig_unified_audit_policy_name }}
-- System-level ACTIONS only (DDL, DCL, session, user management)
-- VULs: O19C-002200, 002300, 002500, 002600, 002700
--
-- Confirmed valid Oracle 19c unified audit ACTIONS keywords:
--   LOGON
--   CREATE/ALTER/DROP USER
--   GRANT, REVOKE
--   CREATE/ALTER/DROP PROCEDURE
--   CREATE/ALTER/DROP FUNCTION
--   CREATE/ALTER/DROP PACKAGE  (covers spec AND body; no separate PACKAGE BODY keyword)
--   CREATE/ALTER/DROP TRIGGER
--   CREATE/ALTER/DROP TABLE, TRUNCATE TABLE
--   CREATE/ALTER/DROP INDEX
--   CREATE/DROP VIEW
--   CREATE/DROP SEQUENCE
--   CREATE/DROP SYNONYM
--   CREATE/DROP DATABASE LINK
-- =============================================================================

DECLARE
  v_exists NUMBER;
BEGIN
  SELECT COUNT(*) INTO v_exists
  FROM   audit_unified_policies
  WHERE  policy_name = '{{ stig_unified_audit_policy_name }}'
    AND  ROWNUM = 1;
  IF v_exists > 0 THEN
    BEGIN
      EXECUTE IMMEDIATE 'NOAUDIT POLICY {{ stig_unified_audit_policy_name }}';
    EXCEPTION WHEN OTHERS THEN NULL;
    END;
    EXECUTE IMMEDIATE 'DROP AUDIT POLICY {{ stig_unified_audit_policy_name }}';
    DBMS_OUTPUT.PUT_LINE('STIG Audit: Dropped existing {{ stig_unified_audit_policy_name }}');
  END IF;
END;
/

CREATE AUDIT POLICY {{ stig_unified_audit_policy_name }}
  ACTIONS
    LOGON,
    CREATE USER,
    ALTER USER,
    DROP USER,
    GRANT,
    REVOKE,
    CREATE PROCEDURE,
    ALTER PROCEDURE,
    DROP PROCEDURE,
    CREATE FUNCTION,
    ALTER FUNCTION,
    DROP FUNCTION,
    CREATE PACKAGE,
    ALTER PACKAGE,
    DROP PACKAGE,
    CREATE TRIGGER,
    ALTER TRIGGER,
    DROP TRIGGER,
    CREATE TABLE,
    ALTER TABLE,
    DROP TABLE,
    TRUNCATE TABLE,
    CREATE INDEX,
    ALTER INDEX,
    DROP INDEX,
    CREATE VIEW,
    DROP VIEW,
    CREATE SEQUENCE,
    DROP SEQUENCE,
    CREATE SYNONYM,
    DROP SYNONYM,
    CREATE DATABASE LINK,
    DROP DATABASE LINK;

AUDIT POLICY {{ stig_unified_audit_policy_name }};

BEGIN
  DBMS_OUTPUT.PUT_LINE('STIG Audit: Policy {{ stig_unified_audit_policy_name }} CREATED and ENABLED');
END;
/

