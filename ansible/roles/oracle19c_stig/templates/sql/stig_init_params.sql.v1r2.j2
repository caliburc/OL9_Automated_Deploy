-- ── O19C-00-000700 -- O7_DICTIONARY_ACCESSIBILITY = FALSE (CAT II) ───────────
-- This is a hidden parameter (_o7_dictionary_accessibility) in Oracle 19c.
-- It does NOT appear in V$PARAMETER -- only in V$PARAMETER2 or X$KSPPI.
-- Cannot be set via ALTER SYSTEM in 19c; requires pfile/spfile recreation.
-- A NO_DATA_FOUND handler is required because the parameter will not be found
-- in V$PARAMETER on a standard 19c install (ORA-01403 without the handler).
{% if stig_O19C_000700_enabled %}
DECLARE
  v_current VARCHAR2(10) := 'FALSE';
BEGIN
  BEGIN
    SELECT value INTO v_current
    FROM   v$parameter2
    WHERE  name = 'o7_dictionary_accessibility';
  EXCEPTION
    WHEN NO_DATA_FOUND THEN
      -- Hidden parameter absent from V$PARAMETER2 on standard 19c installs.
      -- Oracle 19c default is FALSE so treat as compliant.
      v_current := 'FALSE';
    WHEN OTHERS THEN
      DBMS_OUTPUT.PUT_LINE('STIG O19C-000700: WARNING -- could not query parameter: ' || SQLERRM);
      v_current := 'UNKNOWN';
  END;

  IF UPPER(v_current) = 'FALSE' THEN
    DBMS_OUTPUT.PUT_LINE('STIG O19C-000700: O7_DICTIONARY_ACCESSIBILITY=FALSE -- COMPLIANT');
  ELSIF UPPER(v_current) = 'UNKNOWN' THEN
    DBMS_OUTPUT.PUT_LINE('STIG O19C-000700: O7_DICTIONARY_ACCESSIBILITY could not be verified -- review manually');
  ELSE
    -- Parameter is TRUE and must be remediated via pfile.
    -- ALTER SYSTEM is not supported for this hidden parameter in 19c.
    EXECUTE IMMEDIATE 'CREATE PFILE=''/tmp/init_{{ stig_db.sid }}_stig.ora'' FROM SPFILE';
    DBMS_OUTPUT.PUT_LINE('STIG O19C-000700: O7_DICTIONARY_ACCESSIBILITY=' || v_current || ' -- NON-COMPLIANT');
    DBMS_OUTPUT.PUT_LINE('STIG O19C-000700: pfile exported to /tmp/init_{{ stig_db.sid }}_stig.ora');
    DBMS_OUTPUT.PUT_LINE('STIG O19C-000700: ACTION REQUIRED -- add _O7_DICTIONARY_ACCESSIBILITY=FALSE');
    DBMS_OUTPUT.PUT_LINE('STIG O19C-000700: then run: CREATE SPFILE FROM PFILE and restart the DB');
  END IF;
END;
/
{% endif %}

